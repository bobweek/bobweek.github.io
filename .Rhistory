muM <- function(X,P){
y <- numeric(2);
y[1] <- (X[3]*X[4]*P[10] + X[2]*X[3]*P[10] + X[1]*X[4]*P[11] + sqrt(X[1])*X[4] + sqrt(X[1])*X[2] + X[1]*sqrt(X[2]) )
y[2] <- (X[3]*X[4]*P[11] + X[1]*X[4]*P[11] + X[2]*X[3]*P[10] + sqrt(X[2])*X[3] + sqrt(X[1])*X[2] + X[1]*sqrt(X[2]) )
y <- y/(X[3]*X[4] + X[2]*X[3] + X[1]*X[4])
return(y)
}
