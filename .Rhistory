wt1 <- histn[i,1:S[1]]/sum(histn[i,1:S[1]])
wt2 <- histn[i,(1+S[1]):(S[1]+S[2])]/sum(histn[i,(1+S[1]):(S[1]+S[2])])
vm1 <- c( vm1, weighted.mean(histv[i,1:S[1]],                        wt1 ) )
vm2 <- c( vm2, weighted.mean(histv[i,(1+S[1]):(S[1]+S[2])],          wt2 ) )
lnvm1 <- c( lnvm1, weighted.mean(log10(histv[i,1:S[1]]+1e-10),               wt1 ) )
lnvm2 <- c( lnvm2, weighted.mean(log10(histv[i,(1+S[1]):(S[1]+S[2])]+1e-10), wt2 ) )
vv1 <- c( vv1, sum(wt1 * (log10(histv[i,1:S[1]]+1e-10) - lnvm1[i])^2) )
vv2 <- c( vv2, sum(wt2 * (log10(histv[i,(1+S[1]):(S[1]+S[2])]+1e-10) - lnvm2[i])^2) )
minv1 <- c( minv1, min(histv[i,1:S[1]]) )
minv2 <- c( minv2, min(histv[i,(1+S[1]):(S[1]+S[2])]))
}
lw1v <- vm1*10^(-sqrt(vv1))
up1v <- vm1*10^sqrt(vv1)
lw2v <- vm2*10^(-sqrt(vv2))
up2v <- vm2*10^sqrt(vv2)
histv_df <- data.frame(vm1,vm2,lw1v,lw2v,up1v,up2v,t=1:TIME)
pv <- ggplot(histv_df,aes(x=t))+
geom_ribbon(aes(ymin=lw1v,ymax=up1v),alpha=.1,color='maroon',fill='maroon',lty=2)+
geom_ribbon(aes(ymin=lw2v,ymax=up2v),alpha=.1,color='#FFC300',fill='#FFC300',lty=2)+
geom_line(aes(y=vm1),color='maroon',lwd=1)+
geom_line(aes(y=vm2),color='#FFC300',lwd=1)+
scale_y_continuous(trans='log10')+
theme_pubclean()+xlab("time")+ylab("intraspecific variance")
