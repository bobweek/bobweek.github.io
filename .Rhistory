Statistic <- function(D,mu_0,V_0,mu_1,V_1){ # H_1 is assumed to be true
mu_t <- colMeans(D)
n <- nrow(D)
print(mu_t-mu_1)
c <- n*( t(mu_0-mu_t)%*%solve(V_0)%*%(mu_0-mu_t)-
t(mu_1-mu_t)%*%solve(V_1)%*%(mu_1-mu_t)+log(det(V_0)/det(V_1)) )
return(c[1])
}
Statistic(DATA,x,S,x0,S0)
