require(tictoc)
require(ggplot2)
require(ggthemes)
require(ggpubr)
require(gridExtra)
#################################
####                          ###
####   simulating with Rcpp   ###
####                          ###
#################################
A       <- c(1e-5,1e-5)       # strength of abiotic selection
th      <- c(-2,2)            # abiotic optimum for peak activity time (pat)
mutv    <- 5e-1               # mutational variance
segv    <- 0.0                # segregation variance
S       <- c(100,100)         # richness of the guilds
amb_div <- sqrt(1/sqrt(prod(A)))/10
init_div <- 1/100
n <- rpois(S[1]+S[2],100)
zm    <-      rnorm(S[1],th[1],amb_div)
zm    <- c(zm,rnorm(S[2],th[2],amb_div))
zv <- NULL
for(i in 1:S[1])               zv <- c(zv,init_div*rchisq(1,n[i])) # intraspecific variance in peak activity times
for(i in (1+S[1]):(S[1]+S[2])) zv <- c(zv,init_div*rchisq(1,n[i]))
bmu  <- c(-5,-5) # meta parameters determining dist of Bs
bsig <- c(.01,.01)
b  <-     exp(rnorm(S[1],bmu[1],bsig[1]))  # sharpness of activity curves
b  <- c(b,exp(rnorm(S[2],bmu[2],bsig[2])))
# make different for different species
# these should be treated as individual model pars
# can we infer all of these from the network?
# that would really speed up inference
amu  <- c(1,1) # meta parameters determining dist of tas
asig <- c(.01,.01)
a <-      exp(rnorm(S[1],amu[1],asig[1])) # total activities
a <- c(a, exp(rnorm(S[2],amu[2],asig[2])))
e      <- sqrt(2*pi/A)
m      <- c(1.3,1.3)   # max fit-mut
c      <- c(0.8,0.8)   # max fit-comp
parms <- list(A=A,th=th,mutv=mutv,segv=segv,S=S,e=e,m=m,c=c,
amb_div=amb_div,bmu=bmu,bsig=bsig,tamu=amu,tasig=asig)
comm <- list(ZB=zm,ZV=zv,b=b,a=a,n=n,dc=0)
TIME   <- 1000 # number of iterations to run
deathclock <- 0
# do the dang thing
# histG <- NULL
histz <- comm$ZB
histv <- comm$ZV
histn <- comm$n
tic()
for(t in 2:TIME){
simC(comm,parms,1)
deathclock <- deathclock+comm$dc
histz <- rbind(histz,comm$ZB)
histv <- rbind(histv,comm$ZV)
histn <- rbind(histn,comm$n)
}
timesss <- toc()
timesss <- timesss$toc-timesss$tic
hrsss <- (timesss-timesss%%(60*60))/(60*60)
minss <- (timesss-timesss%%60)/60 - 60*hrsss
secss <- timesss - 60*60*hrsss - 60*minss
sprintf("it took %g hours, %g minutes and %g seconds",hrsss,minss,secss)
#########################
#                       #
# EXAMINING THE RESULTS #
#                       #
#########################
par(mfrow=c(1,1))
### plotting histories ###
# abundances
nm1 <- NULL
nm2 <- NULL
for(i in 1:TIME){
nm1 <- c(nm1,10^mean(log10(histn[i,1:S[1]])))
nm2 <- c(nm2,10^mean(log10(histn[i,(1+S[1]):(S[1]+S[2])])))
}
nv1 <- NULL
nv2 <- NULL
for(i in 1:TIME){
nv1 <- c(nv1,var(log10(histn[i,1:S[1]])))
nv2 <- c(nv2,var(log10(histn[i,(1+S[1]):(S[1]+S[2])])))
}
lw1 <- nm1*10^(-sqrt(nv1))
up1 <- nm1*10^sqrt(nv1)
lw2 <- nm2*10^(-sqrt(nv2))
up2 <- nm2*10^sqrt(nv2)
histn_df <- data.frame(nm1,nm2,lw1,up1,lw2,up2,t=1:TIME)
pn <- ggplot(histn_df,aes(x=t))+
geom_ribbon(aes(ymin=lw1,ymax=up1),alpha=.1,color='maroon',fill='maroon',lty=2)+
geom_ribbon(aes(ymin=lw2,ymax=up2),alpha=.1,color='#FFC300',fill='#FFC300',lty=2)+
geom_line(aes(y=nm1),color='maroon',lwd=1)+
geom_line(aes(y=nm2),color='#FFC300',lwd=1)+
scale_y_continuous(trans='log10')+
theme_pubclean()+xlab("time")+ylab("abundance")
# trait means
zm1 <- NULL
zm2 <- NULL
zv1 <- NULL
zv2 <- NULL
for(i in 1:TIME){
wt1 <- histn[i,1:S[1]]/sum(histn[i,1:S[1]])
wt2 <- histn[i,(1+S[1]):(S[1]+S[2])]/sum(histn[i,(1+S[1]):(S[1]+S[2])])
zm1 <- c(zm1,weighted.mean(histz[i,1:S[1]],wt1))
zm2 <- c(zm2,weighted.mean(histz[i,(1+S[1]):(S[1]+S[2])],wt2))
zv1 <- c( zv1, sum(wt1 * (histz[i,1:S[1]] - zm1[i])^2) )
zv2 <- c( zv2, sum(wt2 * (histz[i,(1+S[1]):(S[1]+S[2])] - zm2[i])^2) )
}
histz_df <- data.frame(zm1,zm2,zv1,zv2,t=1:TIME)
pz <- ggplot(histz_df,aes(x=t))+
geom_ribbon(aes(ymin=zm1-sqrt(zv1),ymax=zm1+sqrt(zv1)),alpha=.1,color='maroon',fill='maroon',lty=2)+
geom_ribbon(aes(ymin=zm2-sqrt(zv2),ymax=zm2+sqrt(zv2)),alpha=.1,color='#FFC300',fill='#FFC300',lty=2)+
geom_line(aes(y=zm1),color='maroon',lwd=1)+
geom_line(aes(y=zm2),color='#FFC300',lwd=1)+
theme_pubclean()+xlab("time")+ylab("mean trait")
