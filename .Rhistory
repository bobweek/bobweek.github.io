L <- NULL
for(i in 1:N){
DATA <- mvrnorm(n,x,S)
x0 <- colMeans(DATA)
S0 <- (n-1)*var(DATA)/n
L <- c(L,Statistic(as.matrix(data),x0,S0,x,S))
}
z <- seq(min(L),max(L),length.out=100)
Fh <- NULL
for(i in 1:100){
Fh <- c(Fh,Fhat(z[i],L))
}
plot(z,Fh)
cvalue <- function(x){
return(abs(1-Fhat(x,L)-0.95))
}
print(optimize(cvalue,lower=min(z),upper=max(z))$minimum)
