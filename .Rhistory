b
intxnfreqs <- matrix(0,ncol=S[1],nrow=S[2])
for(i in 1:S[1]){
zb1 <- comm$ZB[i]
s1  <- comm$ZV[i]
b1  <- comm$b[i]
a1  <- comm$a[i]
n1  <- comm$n[i]
for(j in (S[1]+1):(S[1]+S[2])){
zb2 <- comm$ZB[j]
s2  <- comm$ZV[j]
b2  <- comm$b[j]
a2  <- comm$a[j]
n2  <- comm$n[j]
intfrq <- 0
intfrq <- intfrq + n1*n2*meanOverlap(zb1,zb2,b1,b2,a1,a2,s1,s2)
intxnfreqs[j-S[1],i] <- intfrq
}
}
AND <- function(x){
b <- T
for(i in 1:length(x)) b <- b&x[i]
return(b)
}
require(bipartite)
NN <- 1000 # number of observed samples
intxnfreqs_vec <- as.vector(intxnfreqs)
observed_intxn <- sample(prod(S),NN,replace=T,intxnfreqs_vec)
thing <- NULL
for(i in 1:S[1]) for(j in 1:S[2]) thing <- rbind(thing,c(i,j))
combinations <- thing[observed_intxn,]
obs_matrix <- matrix(0,ncol=S[1],nrow=S[2])
for(i in 1:S[1]){
for(j in 1:S[2]){
for(k in 1:NN){
if(AND(combinations[k,]==c(i,j))) obs_matrix[j,i] <- obs_matrix[j,i]+1
}
}
}
plotweb(obs_matrix,empty=F)
isSymmetric.matrix(obs_matrix)
obs_matrix
