1.80,3.60,3.99,2.38,2.68)^2
where <- c("Nagaoka","Kutsuki","Kyoto","Jurinji","Nara","Kiikatsuura","Taiji","Arafune","Kiioshima","Usa","Muroto","Ashizuri","Reihoku","Takahama",
"Yahazu","Shitoko","Fukagawa","Hanyama","Kawahara","Ohko-rindoh")
island <- c(rep("HNS",9),rep("SKK",3),rep("AMK",2),rep("YKI",6))
female_snout_var <- female_snout_var[which(island=="YKI" | island=="AMK")]
camellia_coincidence_var <- camellia_coincidence_var[which(island=="YKI" | island=="AMK")]
camellia_h <- 0.74 # the mean heritability reported
G1 <- 0.5*mean(female_snout_var)
G2 <- camellia_h*mean(camellia_coincidence_var)
m1 <- 0
m2 <- 0
camellia_absence <- c(5.22,5.27,5.48,7.54,4.68,5.19,4.91,4.99,5.55,7.65,6.82,6.42,7.63,7.69,7.28,7.56,6.61)
male_snout <- c(6.19,5.57,5.5,5.45,5.52,5.71,6.01,5.95,6.33,6.42,6.38)
k1 <- 0
k2 <- 0
th_hat_weevil <- mean(male_snout)+k1
th_hat_camellia <- mean(camellia_absence)+k2
th1 <- th_hat_weevil
th2 <- th_hat_camellia
n_weevil   <- c(26389,41944,19167,66389,44167,23333,30278)
n_camellia <- c(1178,1334,2155,1841,3112,2389,1770)
n1 <- 1/mean(1/n_weevil)
n2 <- 1/mean(1/n_camellia)
P <- c(rep(0,5),m1,m2,G1,G2,th1,th2,n1,n2,k1,k2)
# COEV
B1 <- 6.4e-11
B2 <- 2.33e-09
A1 <- 1.19e-06
A2 <- 1.05e-05
MUc  <- muM(c(B1,B2,A1,A2),P)
VCVc <- SIGMAM(c(B1,B2,A1,A2),P)
plot.new()
plot.window(c(0,20),c(0,20))
require(car)
ellipse(MUc,VCVc,0.45,fill=T,col="#f400a7")
# NO BIOTIC SEL
A1 <- 2.76e-07
A2 <- 5.87e-06
MU0  <- muM(c(0,0,A1,A2),P)
VCV0 <- SIGMAM(c(0,0,A1,A2),P)
ellipse(MU0,VCV0,0.45,fill=T,col="#00d36b")
axis(1)
axis(2)
title(xlab="Weevil Rostrum Length",ylab="Camellia Pericarp Thickness")
# the widths and heigths of the ellipses respectively
w0 <- sqrt(VCV0[1,1])/2
h0 <- sqrt(VCV0[2,2])/2
wc <- sqrt(VCVc[1,1])/2
hc <- sqrt(VCVc[2,2])/2
text(MU0[1],MU0[2]-h0-.8,"Without Coevolution")
text(MUc[1],MUc[2]-hc-.8,"With Coevolution")
require(psych) # for trace
KLD <- (log(det(VCVc)/det(VCV0))-2+tr(solve(VCVc)%*%VCV0)+mahalanobis(MUc,MU0,VCVc))
MUc
VCVc
