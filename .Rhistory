M1 <- function(P){
(P[1]-P[10])/( 2*P[12]*( P[5]*(P[10]-P[1])+P[3]*(P[2]-P[10]) ) )
}
M2 <- function(P){
(P[2]-P[11])/( 2*P[13]*( P[5]*(P[11]-P[2])+P[4]*(P[1]-P[11]) ) )
}
A1 <- function(P){
(P[2]-P[1])/( 2*P[12]*( P[5]*(P[10]-P[1])+P[3]*(P[2]-P[10]) ) )
}
A2 <- function(P){
(P[1]-P[2])/( 2*P[13]*( P[5]*(P[11]-P[2])+P[4]*(P[1]-P[11]) ) )
}
